  struct TypeAliasDecl
    source: ast.go:341
    why: "TypeAliasDecl is a type alias: type Name = OtherType"
    field Name: string
    field IsPublic: bool
      doc: "true if declared with `pub`"
    field Type: TypeExpr
    field Span: Span

  struct TypeExpr
    source: ast.go:21
    why: "TypeExpr represents any type expression in Forge."
    field Kind: TypeExprKind
    field Data: any
      doc: "one of NamedType, OptionalType, UnionType, SequenceType, MapType, TupleType, FuncType, ChannelType, or nil for Lock/Unit"
    field Span: Span

  struct TypeExprKind
    why: "Method holder for TypeExprKind's String, giving each type-expression-kind tag a human-readable name."
    method String() string
      source: ast.go:51
      why: "String returns the human-readable name of the type expression kind."

  typedef TypeExprKind: int
    source: ast.go:28
    why: "TypeExprKind discriminates the kinds of type expressions."

  struct TypeParam
    source: ast.go:118
    why: "TypeParam is a type parameter declaration like T or T: Comparable."
    field Name: string
    field Constraint: string
      doc: "empty if unconstrained"
    field Span: Span

  struct UnaryExpr
    source: expr.go:141
    why: "UnaryExpr applies a unary operator to an operand, e.g. -x or !x."
    field Op: UnaryOp
    field Operand: Expr

  typedef UnaryOp: int
    source: expr.go:133
    why: "UnaryOp identifies a unary operator (negation, logical not)."

  struct UnionType
    source: ast.go:70
    why: "UnionType holds variants for T | U."
    field Variants: []TypeExpr

  struct UnwrapExpr
    source: expr.go:225
    why: "UnwrapExpr represents expr! — unwrap an optional value, panic if nil."
    field Operand: Expr

  struct VarDeclStmt
    source: expr.go:310
    why: "VarDeclStmt is a variable declaration, let [mut] x: T = expr, with support for"
    field Name: string
    field Names: []string
      doc: "for tuple destructuring: let (a, b) = expr"
    field Type: *TypeExpr
      doc: "nil if inferred"
    field IsMut: bool
    field Value: *Expr
      doc: "nil if uninitialized"
    field Pattern: *Pattern
      doc: "non-nil for let..else: let Variant(x) = expr else { ... }"
    field ElseBlock: *Block
      doc: "required when Pattern is set"

  struct VariantPattern
    source: expr.go:456
    why: "VariantPattern matches an enum variant and binds its fields, e.g. Some(x)."
    field Name: string
    field Bindings: []Pattern

  struct WhereClause
    source: ast.go:136
    why: "WhereClause constrains type variables."
    field Variable: string
      doc: "empty for bare relational constraints"
    field Constraint: string
    field TypeArgs: []TypeExpr
      doc: "populated for relational constraints: Graph<G, N, E>"
    field Span: Span

  struct WhileStmt
    source: expr.go:362
    why: "WhileStmt loops while a condition holds."
    field Condition: Expr
    field Body: Block

  struct YieldStmt
    source: expr.go:388
    why: "YieldStmt yields a value from a generator."
    field Value: *Expr
      doc: "the expression to yield"
